<main class="section">
  {% if sections.showProductCard %}
  <div class="eyebrow">Products</div>
  <a href="/book" class="product-card" data-track="get_book_click">
    <img src="/book.webp" alt="The Grit Chronicles book">
    <span>Get the book</span>
  </a>
  {% endif %}

  {% if sections.showNewsletter %}
  <div class="eyebrow">Join the newsletter</div>
  <p class="newsletter-copy">
    Get a gritty message every other day in your inbox to kill your excuses and fortify your mind.
  </p>
  <p class="newsletter-copy bold-line">
    No motivation porn. No empty hype. No bullshit. Just pure grit.
  </p>

  <form class="sub-bar listmonk-form" action="https://mail.vendro.cc/subscription/form" method="post" target="_blank" rel="noopener">
    <input type="hidden" name="nonce">
    <input type="email" name="email" placeholder="Enter your email" required>
    <input type="checkbox" name="l" value="{{ site.listmonkListUuid }}" checked hidden>
    <button type="submit">Subscribe</button>
  </form>
  <p class="fine-print">No spam. Unsubscribe at anytime.</p>
  {% endif %}
</main>
