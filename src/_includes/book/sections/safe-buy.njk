<section class="safe-buy section section--grey" id="safe-buy">
  <div class="container">
    <img class="safe-buy-badge" src="/assets/book/images/safe-buy-seal.webp" alt="Safe Buy guarantee seal" loading="lazy">
    <p class="safe-buy-title">Your order is protected.</p>
    <p class="section-subtext center">
      Payments are processed securely, and your information is never shared. If you have any questions, concerns, or issues with your order, just reach out to us at:
    </p>
    <a href="mailto:{{ book.contactEmail }}" class="email-chip">
      <span class="email-chip-text">{{ book.contactEmail }}</span>
    </a>

    <div class="safety-badges">
      <div class="safety-badge">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.7"/>
          <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <span>Secure<br>Checkout</span>
      </div>
      <div class="safety-badge">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M7 11v9H4a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h3Zm0 0 4.2-7.2A2 2 0 0 1 15 5.3V9h4a2 2 0 0 1 1.94 2.5l-1.6 6.9A2 2 0 0 1 17.4 20H9a2 2 0 0 1-2-2v-7Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/>
        </svg>
        <span>Satisfaction Guarantee</span>
      </div>
      <div class="safety-badge">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
          <ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.6"/>
          <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.6"/>
        </svg>
        <span>Worldwide Shipping</span>
      </div>
    </div>
  </div>
</section>
